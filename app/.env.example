# Příklad konfigurace — ZKOPÍRUJ do `.env` a doplň hodnoty.
# Žádné reálné tajné hodnoty zde NIKDY nesmí být. `.env` je v .gitignore.

# ─── Supabase / Postgres ──────────────────────────────────────────────────────
SUPABASE_CONNECTION_STRING=
# Prisma runtime URL (heslo URL-enkódované: % -> %25, ? -> %3F).
DATABASE_URL=
# Přímé (nepoolované) připojení pro `prisma migrate` (port 5432 direct / 6543 pooler).
DIRECT_URL=
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=   # client-exposed (NEXT_PUBLIC_*)
NEXT_PUBLIC_SUPABASE_ANON_KEY=          # client-exposed
SUPABASE_SERVICE_ROLE_KEY=              # SECRET — bypassuje RLS, jen server

# ─── Google Drive ─────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=                   # SECRET
GOOGLE_REFRESH_TOKEN=                   # SECRET
GDRIVE_ROOT_FOLDER_ID=
# Výběr úložiště: "real" = Google Drive (plán 006), jinak stub. Testy vždy stub.
DRIVE_STORAGE=stub

# ─── Telegram ─────────────────────────────────────────────────────────────────
MMM_TELEGRAM_BOT_TOKEN=                 # SECRET
MMM_TELEGRAM_CHAT_ID=
TELEGRAM_BOT_API_BASE_URL=              # optional, e.g. http://127.0.0.1:8081
TELEGRAM_THREAD_GENERAL=
TELEGRAM_THREAD_GALLERY=
TELEGRAM_THREAD_SUGGESTIONS=
TELEGRAM_THREAD_REQUEST=
TELEGRAM_GENERAL_RANDOM_MESSAGES=       # např. zpráva 1|||zpráva 2|||zpráva 3
NEXT_PUBLIC_TELEGRAM_GROUP_URL=         # client-exposed

# ─── Podpisové klíče (HMAC) ───────────────────────────────────────────────────
# Vygeneruj vysokou entropií, různé per prostředí:  openssl rand -base64 48
# V produkci MUSÍ být >=32 znaků a NESMÍ začínat "dev-only-change-me" (viz src/lib/env.ts).
STREAMING_TOKEN_SECRET=                 # SECRET
SESSION_COOKIE_SECRET=                  # SECRET

# ─── Režim ────────────────────────────────────────────────────────────────────
# Platební bariéra (Stripe) vypnutá v MVP; zapíná se hodnotou "true" (R21.3).
PAYMENTS_ENABLED=false
